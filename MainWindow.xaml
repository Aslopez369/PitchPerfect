<Window x:Class="PitchPerfect.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:PitchPerfect.Utils"
        xmlns:vm="clr-namespace:PitchPerfect.ViewModels"
        Title="PitchPerfect - 音频变调控制器"
        Height="650" Width="820"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        ResizeMode="CanMinimize"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <utils:IconConverter x:Key="IconConverter" />
        <utils:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- Slider style -->
        <Style x:Key="PitchSliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="-12"/>
            <Setter Property="Maximum" Value="12"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Foreground" Value="#FF7AA2F7"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <!-- Button style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF45475A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Start button (green) -->
        <Style x:Key="StartButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FF1E3A2F"/>
            <Setter Property="BorderBrush" Value="#FF2A5F3F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2A5F3F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stop button (red) -->
        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FF3A1E1E"/>
            <Setter Property="BorderBrush" Value="#FF5F2A2A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5F2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListView item style -->
        <Style x:Key="SessionListItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Background" Value="#FF1E1E2E"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF313244"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF313244"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="#FF11111B">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="🎵"
                       FontSize="24"
                       Margin="16,8,8,8"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="PitchPerfect - 音频变调控制器"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#FFCDD6F4"
                       Margin="4,10,16,10"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Mode Switcher -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="16,12,16,8">
            <RadioButton Content="全局模式"
                         FontSize="15"
                         Foreground="#FFCDD6F4"
                         Margin="0,0,24,0"
                         IsChecked="{Binding IsGlobalMode, Mode=TwoWay}"
                         Cursor="Hand"/>
            <RadioButton Content="单应用模式"
                         FontSize="15"
                         Foreground="#FFCDD6F4"
                         IsChecked="{Binding IsPerAppMode, Mode=TwoWay}"
                         Cursor="Hand"/>
        </StackPanel>

        <!-- Content Area -->
        <Grid Grid.Row="2" Margin="16,4,16,8">

            <!-- Global Mode Panel -->
            <Border Visibility="{Binding IsGlobalMode, Converter={StaticResource BoolToVis}}"
                    Background="#FF181825"
                    CornerRadius="10"
                    Padding="24">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Pitch Label -->
                    <TextBlock Text="音调控制"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#FF9399B2"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <!-- Pitch Value Display -->
                    <TextBlock Text="{Binding GlobalPitchDisplay}"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="#FF7AA2F7"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <!-- Pitch Slider -->
                    <Slider x:Name="GlobalPitchSlider"
                            Style="{StaticResource PitchSliderStyle}"
                            Width="500"
                            Margin="0,4,0,8"
                            Value="{Binding GlobalPitchSemiTones, Mode=TwoWay}"/>

                    <!-- Tick Labels -->
                    <Grid Width="500" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="-12"
                                   FontSize="12" Foreground="#FF6C7086"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Grid.Column="1" Text="0"
                                   FontSize="12" Foreground="#FF6C7086"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="+12"
                                   FontSize="12" Foreground="#FF6C7086"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Vocal Removal (Karaoke) Toggle -->
                    <CheckBox Content="消除人声（仅伴奏）"
                              FontSize="14"
                              Foreground="#FFCDD6F4"
                              HorizontalAlignment="Center"
                              Margin="0,12,0,0"
                              IsChecked="{Binding VocalRemovalEnabled, Mode=OneWay}"
                              Command="{Binding ToggleVocalRemovalCommand}"
                              IsEnabled="{Binding VocalRemovalApplicable}"
                              Cursor="Hand"
                              ToolTipService.ShowOnDisabled="True"
                              ToolTip="开启后仅保留伴奏（消除居中人声）。需要立体声音源；单声道时将自动禁用。"/>

                    <!-- Start/Stop Buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,16">
                        <Button Content="▶ 开始变调"
                                Style="{StaticResource StartButtonStyle}"
                                Command="{Binding StartGlobalCommand}"/>
                        <Button Content="■ 停止变调"
                                Style="{StaticResource StopButtonStyle}"
                                Command="{Binding StopGlobalCommand}"/>
                    </StackPanel>

                    <!-- Processing Status -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Ellipse Width="12" Height="12"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF6C7086"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGlobalProcessing}" Value="True">
                                            <Setter Property="Fill" Value="#FF40A02B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="#FF9399B2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="未处理"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGlobalProcessing}" Value="True">
                                            <Setter Property="Text" Value="正在处理中"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- VB-Cable Warning (shown when not installed) -->
                    <Border Background="#FF3A2E1E"
                            BorderBrush="#FF5F4A2A"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,10"
                            Margin="0,20,0,0"
                            Visibility="{Binding IsVBcableInstalled, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="{Binding VBCableStatus}"
                                   FontSize="13"
                                   Foreground="#FFF9E2AF"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Per-App Mode Panel -->
            <Border Visibility="{Binding IsPerAppMode, Converter={StaticResource BoolToVis}}"
                    Background="#FF181825"
                    CornerRadius="10"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Refresh Button -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="🔄 刷新列表"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding RefreshSessionsCommand}"
                                DockPanel.Dock="Right"/>
                        <TextBlock Text="正在运行的应用程序"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#FF9399B2"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Session List -->
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Sessions}"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ItemContainerStyle="{StaticResource SessionListItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AudioSessionViewModel}">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- App Icon -->
                                    <Image Grid.Column="0"
                                           Source="{Binding IconPath, Converter={StaticResource IconConverter}, IsAsync=True}"
                                           Width="24" Height="24"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                    <!-- Process Name -->
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFCDD6F4"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ProcessName}"
                                                   FontSize="11"
                                                   Foreground="#FF6C7086"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Pitch Slider -->
                                    <Slider Grid.Column="2"
                                            Style="{StaticResource PitchSliderStyle}"
                                            Margin="12,0"
                                            VerticalAlignment="Center"
                                            Value="{Binding PitchSemiTones, Mode=TwoWay}"/>

                                    <!-- Pitch Value -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding PitchDisplay}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#FF7AA2F7"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>

                                    <!-- Toggle Switch -->
                                    <StackPanel Grid.Column="4"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0">
                                        <Ellipse Width="8" Height="8"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#FF45475A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                                            <Setter Property="Fill" Value="#FF40A02B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <CheckBox Content="变调"
                                                  FontSize="13"
                                                  Foreground="#FFCDD6F4"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="3" Background="#FF11111B" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- VB-Cable Status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FFD20F39"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsVBcableInstalled}" Value="True">
                                        <Setter Property="Fill" Value="#FF40A02B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding VBCableStatus}"
                               FontSize="12"
                               Foreground="#FF9399B2"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Device Info -->
                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentDeviceInfo, StringFormat='设备: {0}'}"
                           FontSize="12"
                           Foreground="#FF9399B2"
                           Margin="24,0,24,0"
                           VerticalAlignment="Center"/>

                <!-- Latency -->
                <TextBlock Grid.Column="2"
                           Text="{Binding LatencyDisplay, StringFormat='延迟: {0}'}"
                           FontSize="12"
                           Foreground="#FF9399B2"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
